{
  "name": "proxmox-api",
  "mcp_route": "/proxmox",
  "server_url": "",
  "auth_headers": {
    "Authorization": "%AUTH_HEADER_SECRET%"
  },
  "routes": {
    "allow": [
      {
        "methods": ["GET"],
        "route_matchers": [".*"],
        "endpoint_matchers": ["^/api2/json/"]
